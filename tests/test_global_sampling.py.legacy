"""
Unit tests for GlobalSamplingC3MPC.

Run without Drake (pure-numpy or light mock only):

    pytest tests/test_global_sampling.py -v

Three test groups:
  1. _traj_cost: hand-computed quadratic on synthetic x_seq/u_seq
  2. Sample generation geometry: proxy position and count (mock plant)
  3. IK seed math: DLS formula produces EE within 5mm of target (mock plant)
"""

import sys
import os
import numpy as np
import pytest

sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))

from control.global_sampling_c3 import GlobalSamplingC3MPC, _sample_labels


# ---------------------------------------------------------------------------
# 1.  _traj_cost  — pure numpy, no Drake needed
# ---------------------------------------------------------------------------

class TestTrajCost:

    def _make_cost(self, n_x=4, n_u=2, N=3, diag_q=2.0, diag_r=1.0,
                   diag_qn=5.0):
        Q   = np.eye(n_x) * diag_q
        R   = np.eye(n_u) * diag_r
        QN  = np.eye(n_x) * diag_qn
        return Q, R, QN

    def test_zero_trajectory(self):
        """All-zero trajectory with zero reference → J = 0."""
        n_x, n_u, N = 4, 2, 3
        Q, R, QN = self._make_cost(n_x=n_x, n_u=n_u, N=N)
        x_ref = np.zeros(n_x)
        x_seq = [np.zeros(n_x)] * (N + 1)
        u_seq = [np.zeros(n_u)] * N

        J = GlobalSamplingC3MPC._traj_cost(x_seq, u_seq, Q, R, QN, x_ref)
        assert J == pytest.approx(0.0, abs=1e-10)

    def test_hand_computed_quadratic(self):
        """J matches a hand-computed sum on a simple trajectory."""
        n_x, n_u, N = 4, 2, 3
        Q   = np.eye(n_x) * 2.0
        R   = np.eye(n_u) * 1.0
        QN  = np.eye(n_x) * 5.0
        x_ref = np.zeros(n_x)

        # x_t = ones * (t+1), u_t = ones * t
        x_seq = [np.ones(n_x) * (t + 1) for t in range(N + 1)]
        u_seq = [np.ones(n_u) * t         for t in range(N)]

        # Running cost:
        # t=0: x=[1,1,1,1] → e^T Q e = 4*2=8;  u=[0,0] → 0
        # t=1: x=[2,2,2,2] → e^T Q e = 16*2=32; u=[1,1] → 2
        # t=2: x=[3,3,3,3] → e^T Q e = 36*2=72; u=[2,2] → 8
        # Terminal: x=[4,4,4,4] → e^T QN e = 64*5=320
        expected = 8 + 0 + 32 + 2 + 72 + 8 + 320   # 442

        J = GlobalSamplingC3MPC._traj_cost(x_seq, u_seq, Q, R, QN, x_ref)
        assert J == pytest.approx(float(expected), rel=1e-9)

    def test_nonzero_reference(self):
        """Cost with a non-zero reference shifts correctly."""
        n_x, n_u, N = 2, 1, 2
        Q   = np.eye(n_x) * 1.0
        R   = np.eye(n_u) * 1.0
        QN  = np.eye(n_x) * 1.0
        x_ref = np.ones(n_x)

        x_seq = [np.zeros(n_x)] * (N + 1)   # all zeros; error = -x_ref = [-1,-1]
        u_seq = [np.zeros(n_u)] * N

        # Each running step: e = [0,0]-[1,1]=[-1,-1] → e^T Q e = 2
        # Terminal: same, QN=Q → 2
        # Control: 0 each step
        expected = 2.0 * N + 2.0   # 6.0

        J = GlobalSamplingC3MPC._traj_cost(x_seq, u_seq, Q, R, QN, x_ref)
        assert J == pytest.approx(expected, rel=1e-9)

    def test_single_step_horizon(self):
        """N=1: only one running step + terminal."""
        n_x, n_u = 3, 2
        Q  = np.diag([1.0, 2.0, 3.0])
        R  = np.eye(n_u) * 0.5
        QN = np.eye(n_x) * 4.0
        x_ref = np.zeros(n_x)

        x0 = np.array([1.0, 2.0, 3.0])   # state at t=0
        x1 = np.array([4.0, 5.0, 6.0])   # state at t=1 (terminal)
        u0 = np.array([1.0, 2.0])

        # t=0: e=[1,2,3] → e^T Q e = 1+8+27=36; u0^T R u0 = 0.5*(1+4)=2.5
        # terminal: e=[4,5,6] → e^T QN e = 4*(16+25+36)=308
        expected = 36 + 2.5 + 308   # 346.5

        J = GlobalSamplingC3MPC._traj_cost([x0, x1], [u0], Q, R, QN, x_ref)
        assert J == pytest.approx(expected, rel=1e-9)


# ---------------------------------------------------------------------------
# 2.  Sample generation geometry — mock Drake plant
# ---------------------------------------------------------------------------

class FakePlant:
    """Minimal Drake MultibodyPlant mock for geometry tests."""

    def __init__(self, ee_pos_3d, n_positions=27, n_velocities=27, n_actuators=7):
        self._ee_pos    = np.array(ee_pos_3d, dtype=float)
        self._n_pos     = n_positions
        self._n_vel     = n_velocities
        self._n_act     = n_actuators
        self._positions = np.zeros(n_positions)

    def num_positions(self):  return self._n_pos
    def num_velocities(self): return self._n_vel
    def num_actuators(self):  return self._n_act

    def world_frame(self):    return "WORLD"

    def CalcPointsPositions(self, ctx, frame, local_pt, ref_frame):
        return self._ee_pos.reshape(3, 1)

    def CalcJacobianTranslationalVelocity(self, ctx, wrt, frame, local_pt,
                                           ref_frame, expr_frame):
        # Identity block in first n_act columns, zeros otherwise
        J = np.zeros((3, self._n_vel))
        J[:, :self._n_act] = np.eye(3, self._n_act)
        return J

    def SetPositions(self, ctx, q):
        self._positions = np.array(q)

    def SetVelocities(self, ctx, v):
        pass


class FakeObjBody:
    def floating_positions_start(self):
        return 7   # standard: arm 7 DOF, then qw,qx,qy,qz,x,y,z

class FakeQuadCost:
    d_push = 0.05
    z_ref  = 0.05

class FakeMPC:
    """Minimal C3MPC-alike for constructor tests."""
    def __init__(self, n_q=27, n_v=27, n_u=7):
        self.formulator  = type("F", (), {
            "n_q": n_q, "n_v": n_v, "n_u": n_u})()
        self.solver      = object()
        self.quad_cost   = FakeQuadCost()
        self.horizon     = 20
        self.dt          = 0.05
        self.torque_limit= 30.0
        self.admm_iter   = 3
        self.last_x_seq  = None


def _make_gs(ee_pos=(0.0, 0.0, 0.05), n_samples=3):
    """Construct a GlobalSamplingC3MPC with mocks, bypassing __init__ Drake calls."""
    plant  = FakePlant(ee_pos)
    obj    = FakeObjBody()
    base   = FakeMPC()

    gs = object.__new__(GlobalSamplingC3MPC)
    gs.base_mpc         = base
    gs.plant            = plant
    gs.ee_frame         = "EE"
    gs.world_frame      = "WORLD"
    gs.obj_body         = obj
    gs.n_samples        = n_samples
    gs.contact_free_kp  = 200.0
    gs.contact_free_kd  = 20.0
    gs.mode_sw_window   = 10
    gs.mode_sw_tol      = 1e-3
    gs.log_diag         = False
    gs._formulator      = base.formulator
    gs._solver          = base.solver
    gs._quad_cost       = base.quad_cost
    gs._horizon         = base.horizon
    gs._dt              = base.dt
    gs._tlim            = base.torque_limit
    gs._admm_iter       = base.admm_iter
    gs.n_u              = 7
    gs.n_q              = 27
    gs.n_v              = 27
    gs._obj_x_idx       = obj.floating_positions_start() + 4   # 11
    gs._obj_y_idx       = obj.floating_positions_start() + 5   # 12
    gs._radius          = base.quad_cost.d_push   # 0.05
    gs._z_ee            = base.quad_cost.z_ref    # 0.05
    gs._eps_contact     = 0.005
    gs.last_x_seq       = None
    gs.last_winning_sample_idx = None
    gs.last_mode        = "free"
    gs._cost_window     = []
    gs._step            = 0
    gs._n_switches      = 0
    gs._prev_mode       = "free"
    return gs


class TestSampleGeneration:

    def test_sample_count(self):
        """len(samples) == n_samples for K = 1, 2, 3, 5."""
        for K in [1, 2, 3, 5]:
            gs = _make_gs(n_samples=K)
            q  = np.zeros(27)
            q[11] = 0.0   # obj x
            q[12] = 0.0   # obj y
            target = np.array([0.3, 0.0])
            samples, *_ = gs._generate_samples(q, None, target)
            assert len(samples) == K, f"K={K}: expected {K} samples, got {len(samples)}"

    def test_sample_k0_is_current_ee(self):
        """k=0 sample equals the current EE position."""
        ee = (0.12, -0.05, 0.05)
        gs  = _make_gs(ee_pos=ee, n_samples=3)
        q   = np.zeros(27)
        q[11], q[12] = 0.0, 0.0
        target = np.array([0.3, 0.0])
        samples, *_ = gs._generate_samples(q, None, target)
        np.testing.assert_allclose(samples[0], np.array(ee), atol=1e-9)

    def test_proxy_position(self):
        """k=1 sample (proxy) is at obj - radius * g_hat at z_ee_target."""
        gs     = _make_gs(n_samples=2)
        radius = gs._radius   # 0.05
        z_ee   = gs._z_ee     # 0.05
        q      = np.zeros(27)
        obj_x, obj_y = 0.1, 0.2
        q[11], q[12] = obj_x, obj_y
        goal = np.array([0.4, 0.2])   # g_hat = [1, 0]
        samples, obj_xy, g_hat, _ = gs._generate_samples(q, None, goal)

        expected_proxy = np.array([
            obj_x - radius * g_hat[0],
            obj_y - radius * g_hat[1],
            z_ee,
        ])
        np.testing.assert_allclose(samples[1], expected_proxy, atol=1e-9)

    def test_proxy_is_behind_box(self):
        """Proxy dot g_hat < 0 (EE is behind box relative to goal direction)."""
        gs  = _make_gs(n_samples=2)
        q   = np.zeros(27)
        q[11], q[12] = 0.0, 0.0
        target = np.array([-0.3, 0.0])    # WEST task: g_hat = [-1, 0]
        samples, obj_xy, g_hat, _ = gs._generate_samples(q, None, target)
        proxy_rel = samples[1][:2] - obj_xy   # vector from obj to proxy
        dot = float(np.dot(proxy_rel, g_hat))
        assert dot < 0.0, (
            f"Proxy should be behind box (dot < 0), got dot={dot:.4f}")

    def test_k1_not_same_as_k0(self):
        """k=1 (proxy) should differ from k=0 (current EE) when EE isn't already at proxy."""
        gs  = _make_gs(ee_pos=(0.0, 0.0, 0.05), n_samples=2)
        q   = np.zeros(27)
        q[11], q[12] = 0.0, 0.0
        target = np.array([0.3, 0.0])   # proxy at (-0.05, 0, 0.05)
        samples, *_ = gs._generate_samples(q, None, target)
        # Current EE is at origin; proxy is at (-0.05, 0, 0.05)
        dist = np.linalg.norm(samples[0] - samples[1])
        assert dist > 0.01, f"k=0 and k=1 should differ; dist={dist}"


# ---------------------------------------------------------------------------
# 3.  IK seed — DLS formula correctness
# ---------------------------------------------------------------------------

class TestIKSeed:

    def test_ik_moves_toward_target(self):
        """q_k EE estimate (via J dq) is closer to target than current EE."""
        ee_pos = np.array([0.0, 0.0, 0.05])
        target = np.array([0.10, 0.0, 0.05])   # 10 cm in x

        gs = _make_gs(ee_pos=ee_pos, n_samples=3)

        q   = np.zeros(27)
        q_k, J_arm = gs._ik_seed(q, target, None)   # plant_ctx=None (FakePlant ignores)

        # Predicted EE from DLS: ee_pos + J_arm @ dq
        dq = q_k[:gs.n_u] - q[:gs.n_u]
        ee_predicted = ee_pos + J_arm @ dq

        dist_before = np.linalg.norm(target - ee_pos)
        dist_after  = np.linalg.norm(target - ee_predicted)
        assert dist_after < dist_before, (
            f"IK should reduce EE error: before={dist_before:.4f}, "
            f"after={dist_after:.4f}")

    def test_ik_within_5mm_for_small_error(self):
        """For a 2cm target offset, predicted EE within 5mm of target."""
        ee_pos = np.array([0.0, 0.0, 0.05])
        target = np.array([0.02, 0.0, 0.05])

        gs = _make_gs(ee_pos=ee_pos, n_samples=3)
        q   = np.zeros(27)
        q_k, J_arm = gs._ik_seed(q, target, None)

        dq           = q_k[:gs.n_u] - q[:gs.n_u]
        ee_predicted = ee_pos + J_arm @ dq
        dist         = np.linalg.norm(target - ee_predicted)
        assert dist < 0.005, f"Predicted EE within 5mm; got {dist*1000:.2f} mm"

    def test_ik_object_positions_unchanged(self):
        """IK only modifies arm DOFs; object positions are unchanged."""
        ee_pos = np.array([0.0, 0.0, 0.05])
        target = np.array([0.05, 0.0, 0.05])

        gs  = _make_gs(ee_pos=ee_pos, n_samples=3)
        q   = np.zeros(27)
        q[7:]  = np.random.default_rng(42).standard_normal(20)   # obj DOFs
        q_orig = q.copy()

        q_k, _ = gs._ik_seed(q, target, None)

        # Object DOFs (indices 7 and beyond) must not change
        np.testing.assert_array_equal(q_k[gs.n_u:], q_orig[gs.n_u:],
            err_msg="IK must not modify object positions")


# ---------------------------------------------------------------------------
# 4.  _sample_labels helper
# ---------------------------------------------------------------------------

class TestSampleLabels:

    def test_label_count(self):
        for K in [1, 2, 3, 4, 5]:
            labels = _sample_labels(K, proxy_angle=0.0)
            assert len(labels) == K, f"K={K}: expected {K} labels, got {len(labels)}"

    def test_label_names(self):
        labels = _sample_labels(3, proxy_angle=0.0)
        assert labels[0] == "current"
        assert labels[1] == "proxy"
        assert "circle" in labels[2]
